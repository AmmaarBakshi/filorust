// /ui/appwindow.slint
import { Button, VerticalBox, HorizontalBox, ListView } from "std-widgets.slint";

export struct GuiFileItem {
    name: string,
    is_dir: bool,
    size_str: string,
    modified_str: string,
}

export component AppWindow inherits Window {
    title: "filorust - File Explorer";
    in-out property <string> current_path: "C:\\";
    in-out property <[GuiFileItem]> files: [];
    
    // Callbacks to send UI interactions back to our Rust backend
    callback back_clicked();
    callback forward_clicked();
    callback up_clicked();
    callback row_double_clicked(int);

    width: 900px;
    height: 600px;
    background: #1e1e1e; // Sleek modern dark theme

    VerticalBox {
        padding: 10px;
        spacing: 10px;

        // 1. Top Navigation Bar (Address Bar & Controls)
        HorizontalBox {
            padding: 0px;
            spacing: 5px;
            max-height: 35px;

            Button { text: "◀"; width: 40px; clicked => { root.back_clicked(); } }
            Button { text: "▶"; width: 40px; clicked => { root.forward_clicked(); } }
            Button { text: "▲"; width: 40px; clicked => { root.up_clicked(); } }
            
            // Address Bar
            Rectangle {
                background: #2d2d2d;
                border-radius: 4px;
                border-width: 1px;
                border-color: #3f3f3f;
                
                Text {
                    text: root.current_path;
                    color: #ffffff;
                    vertical-alignment: center;
                    x: 10px;
                }
            }
        }

        // 2. Main Workspace Split (Sidebar + File List Grid)
        HorizontalBox {
            padding: 0px;
            spacing: 10px;

            // Left Navigation Sidebar
            Rectangle {
                width: 180px;
                background: #252526;
                border-radius: 6px;
                
                VerticalBox {
                    alignment: start;
                    padding: 8px;
                    Text { text: "Quick Access"; font-size: 14px; font-weight: 700; color: #858585; }
                    Button { text: "📁 Home"; }
                    Button { text: "🖥️ This PC"; }
                }
            }

            // Right Main Directory Browser Content List
            Rectangle {
                background: #1a1a1a;
                border-radius: 6px;
                border-width: 1px;
                border-color: #2d2d2d;

                ListView {
                    for file[index] in root.files : Rectangle {
                        height: 35px;
                        background: Math.mod(index, 2) == 0 ? #222222 : #1a1a1a;

                        HorizontalBox {
                            padding: 5px;
                            Text { 
                                text: (file.is_dir ? "📁 " : "📄 ") + file.name; 
                                color: #ffffff;
                                vertical-alignment: center;
                            }
                            Text { 
                                text: file.size_str; 
                                color: #aaaaaa;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                                width: 100px;
                            }
                        }

                        // Capture double click to open folders
                        TouchArea {
                            double-clicked => {
                                root.row_double_clicked(index);
                            }
                        }
                    }
                }
            }
        }
    }
}